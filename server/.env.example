# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`.

# --- REQUIRED in production ---
# Strong random secret used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Manager (org admin) credentials. The password is compared against a bcrypt hash.
# Generate a hash with:
#   node -e "import('bcrypt').then(b=>b.default.hash(process.argv[1],12)).then(console.log)" 'YourStrongPassword'
MANAGER_USERNAME=admin
MANAGER_PASSWORD_HASH=

# --- Optional ---
# Comma-separated list of browser origins allowed to call the API.
# Include your web dev origin and the Capacitor native origins.
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,ionic://localhost

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/esports-nexus

# --- Device verification / App Attest (anti-cheat) ---
# When 'true', the server cryptographically enforces App Attest and FAILS CLOSED until
# verifyAgainstAppleRoot() is implemented. Leave 'false' in dev so the flow is testable.
APP_ATTEST_ENFORCE=false

# Shared secret for the MDM managed-app-inventory webhook (POST /api/attest/mdm-report).
# Required for MANAGED-tier (TestFlight-proof) devices. Generate a random value.
MDM_WEBHOOK_SECRET=

NODE_ENV=development
PORT=5000
